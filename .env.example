# ============================================================
# AI ACADEMY — Biến môi trường mẫu (root)
# Copy file này thành .env và điền giá trị thật.
#   cp .env.example .env
# ============================================================

# ---- Chung ----
NODE_ENV=development

# ============================================================
# BACKEND (apps/api)
# ============================================================
PORT=4000
API_PREFIX=api/v1
# Danh sách origin cho CORS, ngăn cách bởi dấu phẩy
CORS_ORIGINS=http://localhost:3000

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://aiacademy:aiacademy@localhost:5432/aiacademy?schema=public

# ---- Cache (Redis) ----
REDIS_URL=redis://localhost:6379

# ---- JWT (BẮT BUỘC đổi trong production, tối thiểu 16 ký tự) ----
JWT_ACCESS_SECRET=dev-access-secret-change-me-please
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- OpenAI (để trống = AI dùng nội dung fallback, app vẫn chạy) ----
OPENAI_API_KEY=
OPENAI_BASE_URL=
AI_DEFAULT_MODEL=gpt-4o-mini

# ---- Supabase Storage (tùy chọn) ----
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=ai-academy

# ---- Rate limiting ----
THROTTLE_TTL=60
THROTTLE_LIMIT=120
AI_THROTTLE_LIMIT=20

# ============================================================
# FRONTEND (apps/web) — biến NEXT_PUBLIC_* lộ ra client
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
